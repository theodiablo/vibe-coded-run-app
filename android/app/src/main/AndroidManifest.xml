<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Supabase OAuth / magic-link redirect deep link. Must match
                 AUTH_DEEP_LINK in src/supabase.js and the Supabase Auth redirect
                 allow-list. App.jsx completes the PKCE exchange on receipt. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="solutions.camboulive.run" android:host="auth-callback" />
            </intent-filter>

            <!-- Polar OAuth return deep link. Polar redirects to the registered
                 https web origin; the web app's polarPreinit bounces the code
                 here (state marker "polar_import:native:…"). App.tsx stashes it
                 and completePolarAuth exchanges it server-side. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="solutions.camboulive.run" android:host="polar-callback" />
            </intent-filter>

            <!-- Health Connect client declaration (Android 14+, where Health Connect is
                 in the platform). Without this, Health Connect doesn't recognise the app
                 and permission requests return ungranted with no dialog. The target
                 (MainActivity) shows the app, from which the privacy policy is reachable. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>

        </activity>

        <!-- Same Health Connect client declaration for Android 13 and lower, where
             Health Connect is a separate app and expects an exported activity-alias. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Live GPS run tracking (Phase 2). Foreground fine/coarse location plus
         ACCESS_BACKGROUND_LOCATION so recording keeps receiving fixes with the
         screen off — the foreground-service-only model left minutes-long GPS holes
         on some devices once the WebView froze. Background is requested in-context
         (only after the prominent BgLocationDisclosure + a foreground grant, when
         the user starts a run) and the watcher is active only during a run (never
         24/7). Shipping this permission requires the Google Play background-location
         declaration + Data Safety entry — see docs/background-location.md. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service that holds the location while recording. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Persistent "recording run" notification (runtime-requested on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Live heart-rate sensor over Bluetooth LE (chest strap / armband / watch
         broadcasting HR). Scanning is flagged neverForLocation so it never implies
         location access; connect is needed to read the sensor. Used only while a
         run is recording — the GPS foreground service already holds the app then,
         so no extra HR foreground service is declared. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Legacy Bluetooth for API 26-30 (before BLUETOOTH_SCAN/CONNECT); on those
         versions scanning also uses the fine-location permission already declared
         above for GPS. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />

    <!-- Health Connect: read continuous heart rate from the user's watch post-run
         (HeartRateSeries), so no on-watch workout is required. Requires a Google Play
         health-data declaration + privacy policy before release. The read scope below,
         the <queries> block, and the VIEW_PERMISSION_USAGE activity declarations above
         (the plugin ships an empty manifest, so the app must declare them) together let
         Health Connect recognise the app and grant permission. -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />

    <!-- Post-run watch import (WatchImportPlugin): read finished exercise sessions
         and their distance / elevation gain that a watch (e.g. Garmin Connect on
         Android 14+) has written to Health Connect, so a phone-free run still lands
         in the log. Each of these read scopes must also be declared in the Google
         Play health-data declaration before release. -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_ELEVATION_GAINED" />

    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>
</manifest>
