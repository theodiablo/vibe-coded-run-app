# Copy this file to .env.local and fill in your values.
# These are Vite build-time variables — prefix with VITE_ to expose them to the browser.

# Your Supabase project URL (Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase publishable (anon) key — safe to commit, grants nothing on its own.
# Row-Level Security on app_state / profiles is the real boundary.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
