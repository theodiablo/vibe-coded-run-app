{
  "name": "running-coach",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "typecheck:supabase": "deno task check:supabase",
    "typecheck:all": "npm run typecheck && npm run typecheck:supabase",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "og:image": "node scripts/og-image/generate.mjs",
    "store:icon": "node scripts/store-icon/generate.mjs",
    "ios:dist-cert": "node scripts/ios-dist-cert.mjs",
    "ios:icon": "node scripts/store-icon/generate.mjs",
    "eval": "vitest run src/utils/coachAgent.eval.test.ts",
    "eval:live": "vitest run --config evals/coach/vitest.config.mjs"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-community/bluetooth-le": "^8.2.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@fontsource/archivo": "^5.2.8",
    "@pianissimoproject/capacitor-health-connect": "^0.7.1",
    "@supabase/supabase-js": "^2.107.0",
    "i18next": "^26.3.6",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "posthog-js": "^1.393.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.9",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "comments": {
    "overrides": "@pianissimoproject/capacitor-health-connect declares a @capacitor/core ^7 peer, but this app is on Capacitor 8 (whose Android plugin API is compatible). Override the peer so a NORMAL npm install resolves — avoiding --legacy-peer-deps, which skips ALL peer auto-installs and silently drops recharts' react-is peer, breaking the build."
  },
  "overrides": {
    "@pianissimoproject/capacitor-health-connect": {
      "@capacitor/core": "$@capacitor/core"
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.2",
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "supabase": "^2.105.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
